# Backend
# SQLAlchemy database URL
DATABASE_URL=sqlite:///./backend/data/app.db

# Comma-separated allowed origins for FastAPI CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

# Mobile (Expo)
# Base URL used by mobile app API client
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
